rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isApproved() {
      return isAdmin() || (
        isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'pending') == 'approved'
      );
    }

    function setupComplete() {
      return exists(/databases/$(database)/documents/config/setup);
    }

    // ---- CONFIG ----
    // 'setup' doc is readable by anyone (to check if first-run is done).
    // Writable only before setup completes, or by an admin afterward.
    match /config/{docId} {
      allow read: if true;
      allow write: if !setupComplete() || isAdmin();
    }

    // ---- USERS ----
    match /users/{userId} {
      allow read: if isAuth();

      // Creating own profile: role must be 'user' — unless this is the first
      // admin being created during setup (before config/setup exists).
      allow create: if isAuth() &&
        request.auth.uid == userId && (
          request.resource.data.role == 'user' ||
          (!setupComplete() && request.resource.data.role == 'admin')
        );

      // Users can update their own profile but cannot change their role or status.
      // Admins can update any profile field.
      allow update: if isAdmin() ||
        (isAuth() && request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status']));

      allow delete: if isAdmin();
    }

    // ---- EVENTS ----
    match /events/{eventId} {
      allow read: if isApproved();
      allow create, delete: if isAdmin();
      // Admins can update anything; approved users can only update ticketSets
      // (needed for claim/release transactions that mark sets available/unavailable).
      allow update: if isAdmin() ||
        (isApproved() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ticketSets']));
    }

    // ---- CLAIMS ----
    match /claims/{claimId} {
      // Admins see all claims; approved users see only their own.
      allow read: if isAdmin() ||
        (isApproved() && resource.data.userId == request.auth.uid);

      // Only approved users can create claims for themselves.
      allow create: if isApproved() &&
        request.resource.data.userId == request.auth.uid;

      // Users can release only their own claimed (not transferred) tickets.
      // Admins can do anything.
      allow update: if isAdmin() ||
        (isApproved() &&
         resource.data.userId == request.auth.uid &&
         resource.data.status == 'claimed' &&
         request.resource.data.status == 'released');

      allow delete: if isAdmin();
    }
  }
}
